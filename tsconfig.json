{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "baseUrl": ".",
        "paths": {
            "~/*": [
                "./app/*"
            ],
            "@/*": [
                "./app/*"
            ]
        }
    },
    "include": [
      "app/**/*.ts",
      "app/**/*.tsx",
      "app/**/*.vue",
      "server/**/*.ts",
      "types/**/*.ts",
      ".nuxt/types/nitro-imports.d.ts"
    ],
    "exclude": [
        "node_modules",
        ".nuxt",
        ".output"
    ]
}